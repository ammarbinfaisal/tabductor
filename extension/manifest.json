{
  "manifest_version": 3,
  "name": "Tabductor",
  "version": "0.1.0",
  "description": "Tab conductor for Tabductor MCP.",
  "permissions": ["activeTab", "debugger", "scripting", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tabductor",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
